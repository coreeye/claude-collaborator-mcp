# Required: Path to your C# codebase root
# Use absolute path for best results
CSHARP_CODEBASE_PATH=/path/to/your/csharp/project

# Optional: GLM API key for AI-assisted exploration
# Get your key from: https://open.bigmodel.cn/
GLM_API_KEY=your_glm_api_key_here

# Optional: GLM model to use
# Common options: glm-4.7, glm-4-flash, glm-4-plus
GLM_MODEL=glm-4.7

# Optional: Custom memory path
# Default: .codebase-memory/ in your codebase root
# MEMORY_PATH=.codebase-memory
